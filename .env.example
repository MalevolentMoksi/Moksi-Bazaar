# === Required ===
TOKEN=your_discord_bot_token
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === Optional ===
# DISCORD_TOKEN=alternative_token_var (TOKEN takes precedence)
# CLIENT_ID=your_application_id (auto-detected from client.user.id if missing)
# OPENROUTER_API_KEY=your_openrouter_key (required for /speak, media analysis, sentiment)
# LANGUAGE_API_KEY=your_groq_key (required for /shh command)
# OWNER_ID=your_discord_user_id
# NODE_ENV=production
# LOG_LEVEL=info
